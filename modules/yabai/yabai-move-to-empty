#!/usr/bin/env bash
# yabai-move-to-empty
# 現在のアクティブウィンドウを「空のスペース」に移動し、そのスペースへフォーカスする。
# 依存: yabai, jq, (fallbackとして osascript)
set -euo pipefail

err() { printf '[yabai-move-to-empty] %s\n' "$*" >&2; }
notify() {
  /usr/bin/osascript -e "display notification \"$*\" with title \"yabai-move-to-empty\"" >/dev/null 2>&1 || true
}
fail() {
  err "$*"
  notify "$*"
  exit 1
}

require() {
  command -v "$1" >/dev/null 2>&1 || fail "require: $1 not found"
}
require yabai
require jq

# アクティブウィンドウが無い場合の軽いガード
if ! yabai -m query --windows --window >/dev/null 2>&1; then
  fail "no active window to move"
fi

# 移動するウィンドウの情報を保存
window_json="$(yabai -m query --windows --window)"
window_id="$(echo "$window_json" | jq -r '.id')"
display_id="$(echo "$window_json" | jq -r '.display')"

find_empty_space() {
  local spaces_json windows_json
  spaces_json="$(yabai -m query --spaces --display "$display_id")"
  windows_json="$(yabai -m query --windows)"

  jq -nr \
    --argjson spaces "$spaces_json" \
    --argjson windows "$windows_json" '
      ($windows
        | map(select(
            (."is-sticky" != true)
            and (."has-ax-reference" == true)
            and (."can-move" == true)
          ))
        | map(.id)
      ) as $occupied_window_ids
      | $spaces
      | map(select(."is-native-fullscreen" == false))
      | map(select(
          all((.windows // [])[]; . as $window_id | ($occupied_window_ids | index($window_id)) == null)
        ))
      | .[0].index // empty
    '
}

create_space() {
  if yabai -m space --create >/dev/null 2>&1; then
    return 0
  fi

  sudo -n yabai --load-sa >/dev/null 2>&1 || return 1
  sleep 0.1
  yabai -m space --create >/dev/null 2>&1
}

# 1) 既存の空スペースを探す
empty_idx="$(find_empty_space)"

target_idx=""
if [[ -n "${empty_idx:-}" ]]; then
  target_idx="$empty_idx"
else
  # 2) 空が無ければ作成を試みる（yabaiのspace --create）
  if create_space; then
    sleep 0.05
    target_idx="$(find_empty_space)"
  else
    fail "no empty space and cannot create a new space"
  fi
fi

# 4) ウィンドウを移動して、そのスペースへフォーカス
if [[ -z "${target_idx:-}" ]]; then
  fail "failed to determine target space index"
fi

yabai -m window --space "$target_idx" || fail "failed to move window to space $target_idx"
yabai -m space --focus "$target_idx" || fail "failed to focus space $target_idx"
yabai -m window --focus "$window_id" || fail "failed to refocus moved window"
